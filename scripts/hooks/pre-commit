#!/usr/bin/env bash
# Auto-format staged Rust files and re-stage them.
#
# Why not run clippy too? Clippy recompiles and can take 30s+; that's too slow
# for the commit path. CI runs clippy — run it yourself before `git push`.
#
# Caveat: if you used `git add -p` to stage only a hunk, rustfmt formats the
# whole file and re-stages it. That can widen the commit beyond your intent.
# Accept it (style-only) or skip the hook intentionally — don't `--no-verify`.

set -euo pipefail

staged_rs=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.rs$' || true)
if [ -z "$staged_rs" ]; then
    exit 0
fi

if ! command -v rustfmt >/dev/null 2>&1; then
    echo "pre-commit: rustfmt not found in PATH; skipping fmt check." >&2
    exit 0
fi

# Format in place.
printf '%s\n' "$staged_rs" | xargs rustfmt --edition 2021

# Re-stage whatever fmt touched.
printf '%s\n' "$staged_rs" | xargs git add

# Final sanity check — should be a no-op after the format above.
if ! printf '%s\n' "$staged_rs" | xargs rustfmt --edition 2021 --check >/dev/null 2>&1; then
    echo "pre-commit: rustfmt still reports diffs after auto-format; inspect manually." >&2
    exit 1
fi
